{
  "expo": {
    "name": "My Garden Care",
    "slug": "MiJardinApp",
    "scheme": "mijardin",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f0e6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mygardencare.app",
      "buildNumber": "11",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDisplayName": "My Garden Care",
        "CFBundleDevelopmentRegion": "en",
        "NSCameraUsageDescription": "Allow access to the camera to take photos of your plants",
        "NSPhotoLibraryUsageDescription": "Allow access to your photos to identify plants",
        "NSLocationWhenInUseUsageDescription": "Allow access to your location to get local weather data",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1",
              "0A2A.1",
              "3B52.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1",
              "85F4.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "app.mygardencare.app",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f0e6"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "locales": {
      "es": "./locales/ios/es.json",
      "en": "./locales/ios/en.json"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5b9a6a",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos to identify plants",
          "cameraPermission": "Allow access to the camera to take photos of your plants"
        }
      ],
      "expo-localization",
      "./plugins/withDisableExtraTranslationLint"
    ],
    "extra": {
      "eas": {
        "projectId": "b0bc8bf8-e038-41e4-8b6e-6bf6dd868b4d"
      }
    },
    "owner": "cristianlopez"
  }
}
